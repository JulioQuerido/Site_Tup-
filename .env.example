# Supabase Configuration Keys for Tupã Hub
# Copie para .env (que NAO e versionado) e preencha com as chaves do projeto.
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key-here

# E-mail autorizado a acessar o painel admin (opcional).
VITE_ADMIN_EMAIL=admin@example.com
